# Runtime/build binaries are downloaded and verified; never commit them.
src-tauri/binaries/*
!src-tauri/binaries/fetch-aether.sh
!src-tauri/binaries/fetch-aether.ps1
!src-tauri/binaries/fetch-singbox.sh
!src-tauri/binaries/fetch-singbox.ps1

# Aether writes its provisioned device identity (private keys, access
# tokens) into its working directory during manual testing — never commit it.
src-tauri/binaries/*.toml
*.log
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store

# CI-built bundles downloaded for local testing
/ci-artifacts/
