{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aether-GUI",
  "version": "0.5.1",
  "identifier": "com.cluvexstudio.aethergui",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aether-GUI",
        "width": 420,
        "height": 640,
        "resizable": false,
        "center": true,
        "decorations": false,
        "backgroundColor": "#0D0D0F"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; object-src 'none'; frame-src 'none'; base-uri 'none'; form-action 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/*.exe",
      "binaries/*.dll",
      "binaries/*-version.txt"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgyNjlDRkUwMDA4NjNGRDYKUldUV1A0WUE0TTlwZ2lsbldCdlFYUzM4K1pUejd4dW4yOGFhUWdmUUhiUWhUYjNuY3hDYldzbmEK",
      "endpoints": [
        "https://github.com/Nishef1/Aether-GUI/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
